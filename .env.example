# ---------------------------------------------------------------------------
# Crystal Touch environment variables
# Copy this file to `.env` and fill in the values from your Supabase project.
# (Supabase dashboard -> Project Settings -> API keys)
# ---------------------------------------------------------------------------

# --- Frontend (exposed to the browser, must be prefixed with VITE_) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Browser-safe key. Use the new "publishable" key (sb_publishable_...).
# (Legacy projects can use VITE_SUPABASE_ANON_KEY instead — both are supported.)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Base URL used when generating client-facing booking links (no trailing slash).
VITE_SITE_URL=http://localhost:5173

# --- Netlify functions (server-side only, NEVER expose these / no VITE_ prefix) ---
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Secret key with full access. Use the new "secret" key (sb_secret_...).
# (Legacy projects can use SUPABASE_SERVICE_ROLE_KEY instead — both are supported.)
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# Storage bucket used for cleaner job photos (created by supabase/schema.sql).
SUPABASE_STORAGE_BUCKET=job-photos
